				>
				["at0004"] = <
					text = <"Does not wish for euthanasia">
					description = <"The individual does not wish for euthanasia.">
				>
				["at0005"] = <
					text = <"Unknown">
					description = <"The individual's position on euthanasia is unknown.">
				>
				["at0006"] = <
					text = <"No euthanasia declaration, but could make a request in certain situations">
